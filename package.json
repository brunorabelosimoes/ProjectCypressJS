{
  "name": "projectcypressjs",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:parallel": "cypress run --record --parallel",
    "cy:run:report": "cypress run --reporter mochawesome --reporter-options reportDir=cypress/reports,overwrite=false,html=false,json=true",
    "report:merge": "mochawesome-merge cypress/reports/*.json > cypress/reports/report.json",
    "report:generate": "marge cypress/reports/report.json -f report -o cypress/reports/html",
    "test": "npm run cy:run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "cypress": "^15.10.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.3.2",
    "pdfkit": "^0.17.2",
    "wait-on": "^7.0.1"
  }
}
